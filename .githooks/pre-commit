#!/usr/bin/env bash
# Pre-commit hook: auto-format Markdown before commit
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)
[ -z "$STAGED" ] && exit 0

npm run format

# Re-stage formatted files
git diff --name-only --diff-filter=M | grep '\.md$' | xargs -r git add
